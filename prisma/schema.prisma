// Rental Management App — Prisma 7 Schema
// Using SQLite for local dev. To switch to PostgreSQL:
//   1. Change provider to "postgresql"
//   2. Update DATABASE_URL in .env

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────────────────────────────────────
// Note: SQLite has no native enum support. String fields are used throughout;
// valid values are enforced at the application/Zod layer.
//
// String enums used in this schema:
//   PropertyType:         HOUSE | APARTMENT | HMO | STUDIO | OTHER
//   PropertyStatus:       ACTIVE | INACTIVE | ARCHIVED
//   RoomStatus:           VACANT | OCCUPIED | MAINTENANCE | RESERVED
//   TenantStatus:         ACTIVE | PAST | PENDING | BLOCKED
//   OccupancyStatus:      ACTIVE | ENDED | PENDING
//   PaymentStatus:        PAID | UNPAID | PARTIAL | OVERDUE | WAIVED
//   PaymentMethod:        BANK_TRANSFER | CASH | STANDING_ORDER | OTHER
//   DepositStatus:        PENDING | PARTIAL | RECEIVED | REFUNDED | PARTIAL_REFUND | DEDUCTED
//   DepositTxType:        RECEIVED | DEDUCTION | REFUND | ADJUSTMENT
//   UserRole:             ADMIN | VIEWER
//   ExpenseCategory:      ELECTRICITY | GAS | WATER | HEATING | INTERNET | INSURANCE |
//                         MAINTENANCE | REPAIRS | CLEANING | TAXES | OTHER
//   RecurrenceType:       MONTHLY | QUARTERLY | ANNUAL | ONE_OFF
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String   // bcrypt hash — never exposed to client
  name         String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activityLogs ActivityLog[]
}

model Property {
  id           String   @id @default(cuid())
  name         String
  address      String
  city         String
  postcode     String?
  country      String   @default("UK")
  propertyType String   @default("HOUSE")
  status       String   @default("ACTIVE")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rooms         Room[]
  expenses      PropertyExpense[]
  mortgages     Mortgage[]
  propertyNotes Note[]           @relation("PropertyNotes")
  activityLogs  ActivityLog[]    @relation("PropertyActivity")
}

// Owner-side property expense tracking (utilities, insurance, maintenance, etc.)
// Separate from tenant rent payments — do not conflate.
//
// reportingYear + reportingMonth control which month bucket an entry appears in.
// They default to the paymentDate's year/month but can be overridden by the user
// (e.g. "Electricity for February" paid in March → reportingMonth = 2).
//
// receiptStorageUrl is internal (Vercel Blob or local:// scheme).
// Clients access receipts via /api/expenses/[id]/receipt which enforces auth.
model PropertyExpense {
  id                  String    @id @default(cuid())
  propertyId          String
  title               String    // "Electricity for February", "Q1 Insurance", etc.
  category            String    // ELECTRICITY | GAS | WATER | HEATING | INTERNET |
                                // INSURANCE | MAINTENANCE | REPAIRS | CLEANING | TAXES | OTHER
  amount              Float
  paymentDate         DateTime  // when the bill was paid / recorded
  reportingYear       Int       // UI grouping: which year this entry belongs to
  reportingMonth      Int       // UI grouping: 1–12, which month this entry belongs to
  coverageStart       DateTime? // optional: billing period start
  coverageEnd         DateTime? // optional: billing period end
  recurrenceType      String    @default("ONE_OFF") // MONTHLY | QUARTERLY | ANNUAL | ONE_OFF
  provider            String?   // "British Gas", "BT", etc.
  notes               String?
  receiptStorageUrl   String?   // internal — never sent to client
  receiptFileName     String?
  receiptFileSize     Int?      // bytes
  receiptUploadedAt   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  property            Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Room {
  id              String   @id @default(cuid())
  propertyId      String
  name            String   // "Blue Room", "Room 1", "Garden Room"
  floor           String?
  sizeM2          Float?
  furnished       Boolean  @default(true)
  privateBathroom Boolean  @default(false)
  monthlyRent     Float
  depositAmount   Float
  status          String   @default("VACANT")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property        Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  occupancies     Occupancy[]
  roomNotes       Note[]        @relation("RoomNotes")
  activityLogs    ActivityLog[] @relation("RoomActivity")
}

// Occupancy = one lease period: Tenant ↔ Room for a date range
// All Payments and the Deposit belong to an Occupancy, not directly to a Tenant
model Tenant {
  id               String    @id @default(cuid())
  firstName        String
  lastName         String
  email            String    @unique
  phone            String?
  nationality      String?
  dateOfBirth      DateTime?
  emergencyContact String?   // JSON: { name, phone, relationship }
  idType           String?   // PASSPORT | DRIVERS_LICENSE | NATIONAL_ID
  idReference      String?
  status           String    @default("ACTIVE")
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  occupancies      Occupancy[]
  tenantNotes      Note[]           @relation("TenantNotes")
  activityLogs     ActivityLog[]    @relation("TenantActivity")
  documents        TenantDocument[]
}

// Documents attached to a tenant — one record per document type
// storageUrl is the Vercel Blob URL; it is NEVER sent to the client.
// Clients access files through /api/documents/[id] which enforces auth.
//
//   DocumentType: idDocument | workContract | salarySlip
//
model TenantDocument {
  id          String   @id @default(cuid())
  tenantId    String
  type        String   // idDocument | workContract | salarySlip
  fileName    String
  fileType    String   // MIME type: application/pdf | image/jpeg | image/png
  fileSize    Int      // bytes
  storageUrl  String   // Vercel Blob URL — internal only
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
}

model Occupancy {
  id              String    @id @default(cuid())
  roomId          String
  tenantId        String
  leaseStart      DateTime
  leaseEnd        DateTime?
  moveInDate      DateTime?
  moveOutDate     DateTime?
  monthlyRent     Float     // agreed rent for this lease (may differ from room.monthlyRent)
  depositRequired Float
  rentDueDay      Int       @default(1) // 1–28: day of month rent is due
  status          String    @default("ACTIVE")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Active rental contract — stored on the tenancy, surfaced on the room screen.
  // contractStorageUrl is internal (Vercel Blob or local:// scheme).
  // Clients access it via /api/occupancies/[id]/contract which enforces auth.
  contractStorageUrl   String?
  contractFileName     String?
  contractFileSize     Int?      // bytes
  contractUploadedAt   DateTime?

  room            Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments        Payment[]
  deposit         Deposit?
  activityLogs    ActivityLog[] @relation("OccupancyActivity")
}

// One record per calendar month per occupancy
model Payment {
  id            String    @id @default(cuid())
  occupancyId   String
  periodYear    Int       // 2026
  periodMonth   Int       // 1–12
  amountDue     Float
  amountPaid    Float     @default(0)
  status        String    @default("UNPAID")
  paidAt        DateTime?
  dueDate       DateTime
  paymentMethod String?
  reference     String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  occupancy     Occupancy @relation(fields: [occupancyId], references: [id], onDelete: Cascade)
  paymentNotes  Note[]    @relation("PaymentNotes")

  @@unique([occupancyId, periodYear, periodMonth])
}

// One deposit per occupancy
model Deposit {
  id             String    @id @default(cuid())
  occupancyId    String    @unique
  required       Float
  received       Float     @default(0)
  receivedAt     DateTime?
  status         String    @default("PENDING")
  refunded       Boolean   @default(false)
  refundAmount   Float?
  refundedAt     DateTime?
  deductionNotes String?
  // Set when tenancy ends: moveOutDate + 30 days.
  // Drives the "deposit return due" reminder on the room screen.
  refundDueDate  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  occupancy      Occupancy            @relation(fields: [occupancyId], references: [id], onDelete: Cascade)
  transactions   DepositTransaction[]
}

model DepositTransaction {
  id          String   @id @default(cuid())
  depositId   String
  type        String   // RECEIVED | DEDUCTION | REFUND | ADJUSTMENT
  amount      Float
  date        DateTime
  description String?
  createdAt   DateTime @default(now())

  deposit     Deposit  @relation(fields: [depositId], references: [id], onDelete: Cascade)
}

// Polymorphic notes — one model, linked to any entity via nullable FK
model Note {
  id         String   @id @default(cuid())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  propertyId String?
  roomId     String?
  tenantId   String?
  paymentId  String?

  property   Property? @relation("PropertyNotes", fields: [propertyId], references: [id], onDelete: Cascade)
  room       Room?     @relation("RoomNotes", fields: [roomId], references: [id], onDelete: Cascade)
  tenant     Tenant?   @relation("TenantNotes", fields: [tenantId], references: [id], onDelete: Cascade)
  payment    Payment?  @relation("PaymentNotes", fields: [paymentId], references: [id], onDelete: Cascade)
}

// Mortgage tracking for a property.
// Amortization is calculated dynamically — nothing is stored beyond these fields.
// startDate = first payment date; balance at startDate = initialBalance.
// termMonths defines the end date: endDate = startDate + termMonths months.
model Mortgage {
  id             String   @id @default(cuid())
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  label          String?  // e.g. "Main Mortgage", "Second Charge"
  lender         String?  // e.g. "Nationwide", "Halifax"

  startDate      DateTime // First payment date — amortization begins here
  termMonths     Int      // Total term in months from startDate
  initialBalance Float    // Loan balance at startDate
  interestRate   Float    // Annual interest rate as a percentage (e.g. 3.5)
  monthlyPayment Float    // Fixed monthly payment amount

  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Lightweight audit trail — records major system events
model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // PROPERTY_CREATED | ROOM_ADDED | TENANT_ASSIGNED | PAYMENT_RECORDED | TENANT_MOVED_OUT …
  description String
  entityType  String   // PROPERTY | ROOM | TENANT | OCCUPANCY | PAYMENT | DEPOSIT
  entityId    String
  metadata    String?  // JSON for extra context
  createdAt   DateTime @default(now())

  userId      String?
  user        User?      @relation(fields: [userId], references: [id])

  propertyId  String?
  roomId      String?
  tenantId    String?
  occupancyId String?

  property    Property?  @relation("PropertyActivity", fields: [propertyId], references: [id], onDelete: SetNull)
  room        Room?      @relation("RoomActivity", fields: [roomId], references: [id], onDelete: SetNull)
  tenant      Tenant?    @relation("TenantActivity", fields: [tenantId], references: [id], onDelete: SetNull)
  occupancy   Occupancy? @relation("OccupancyActivity", fields: [occupancyId], references: [id], onDelete: SetNull)
}
